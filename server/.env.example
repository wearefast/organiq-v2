# ============================================================
# Pulse OS — Server Environment Variables
# Copy to .env and fill in real values. Never commit .env.
# REQUIRED = server will refuse to start without this value.
# OPTIONAL = has a sensible default or is feature-gated.
# ============================================================

# ── Database (REQUIRED) ─────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/pulse_v2

# ── Redis (REQUIRED) ────────────────────────────────────────
REDIS_URL=redis://host:6379
# Set to "true" on AWS ElastiCache if not on same private VPC subnet
REDIS_TLS=false

# ── Clerk Auth (REQUIRED) ────────────────────────────────────
CLERK_SECRET_KEY=sk_live_...
CLERK_WEBHOOK_SECRET=whsec_...
# Optional: override the Clerk domain (defaults to clerk.accounts.dev in dev)
# CLERK_DOMAIN=your-clerk-domain.clerk.accounts.dev

# ── Super-Admin (REQUIRED for admin ops) ─────────────────────
# Comma-separated internal Clerk user IDs that have super-admin access.
# NEVER set as NEXT_PUBLIC_* — keep server-side only.
SUPER_ADMIN_CLERK_IDS=user_xxx,user_yyy

# ── AI Providers (REQUIRED) ──────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
# Optional AI providers
PERPLEXITY_API_KEY=pplx-...
GEMINI_API_KEY=...

# ── SEO Data APIs (REQUIRED) ─────────────────────────────────
AHREFS_API_KEY=...
SERPER_API_KEY=...
FIRECRAWL_API_KEY=fc-...
DATAFORSEO_LOGIN=user@example.com
DATAFORSEO_PASSWORD=...
# Optional
PAGESPEED_API_KEY=...
BING_SEARCH_API_KEY=...

# ── Stripe Billing (REQUIRED in production) ──────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_AGENCY=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# ── Email (OPTIONAL — skips email delivery if absent) ────────
SENDGRID_API_KEY=SG....
EMAIL_FROM=notifications@yourdomain.com

# ── Google Search Console OAuth (OPTIONAL) ───────────────────
GSC_CLIENT_ID=...
GSC_CLIENT_SECRET=...
GSC_REDIRECT_URI=https://api.yourdomain.com/integrations/gsc/callback
# REQUIRED if GSC integration is enabled — used to encrypt OAuth tokens at rest
GSC_ENCRYPTION_KEY=...

# ── Python Sidecar (OPTIONAL — GSC data processing) ──────────
PYTHON_SIDECAR_URL=http://localhost:8000
# Shared secret for NestJS → sidecar requests (set same value in sidecar)
PYTHON_SIDECAR_SECRET=change-me-in-production

# ── Prompt Console (OPTIONAL) ────────────────────────────────
PROMPT_SOURCE=local
PROMPT_CONSOLE_URL=https://console.yourdomain.com
PROMPT_CONSOLE_API_KEY=...

# ── Runtime (OPTIONAL) ───────────────────────────────────────
NODE_ENV=production
PORT=3002
LOG_LEVEL=info
FRONTEND_URL=https://app.yourdomain.com
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-5

{
  "name": "@pulse-os/server",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/db/seed.ts",
    "prompts:sync": "tsx scripts/deploy-agents.ts",
    "prompts:diff": "tsx scripts/deploy-agents.ts --diff",
    "prompts:eval": "vitest run src/prompts/__eval__/"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "@clerk/backend": "^3.8.0",
    "@nestjs/bullmq": "^10.1.0",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/platform-socket.io": "^10.3.0",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^7.3.0",
    "@nestjs/testing": "^10.4.22",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^10.3.0",
    "@types/pdfmake": "^0.3.3",
    "bullmq": "^5.7.0",
    "cheerio": "^1.2.0",
    "chrome-launcher": "^1.2.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "cron-parser": "^5.5.0",
    "drizzle-orm": "^0.36.0",
    "ioredis": "^5.4.0",
    "jose": "^6.2.3",
    "lighthouse": "^13.1.0",
    "nestjs-pino": "^4.6.1",
    "openai": "^6.35.0",
    "pdfmake": "^0.3.8",
    "pg": "^8.12.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.14.0",
    "rxjs": "^7.8.1",
    "stripe": "^22.1.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "@nestjs/schematics": "^10.1.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.0",
    "@types/pg": "^8.11.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.6",
    "drizzle-kit": "^0.28.0",
    "esbuild": "^0.28.1",
    "supertest": "^7.2.2",
    "tsx": "^4.11.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.6"
  }
}
